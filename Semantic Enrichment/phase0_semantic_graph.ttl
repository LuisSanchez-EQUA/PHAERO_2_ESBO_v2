@prefix bem: <https://example.com/bem#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix ex: <http://example.org/phaero#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:1_EAST a brick:Room ;
    bem:hasSurface ex:1_EAST_WALL_1,
        ex:1_EAST_WALL_2,
        ex:1_EAST_WALL_3,
        ex:1_EAST_WALL_4 ;
    bem:orientation "EAST" ;
    bem:roomHeight 4e+00 ;
    bem:roomLength 7e+00 ;
    bem:roomWidth 7e+00 ;
    bem:zoneMultiplier 2e+00 ;
    bem:zoneName "1_EAST" ;
    bem:zoneType "1" .

ex:1_INTERNAL_ONLY a brick:Room ;
    bem:hasSurface ex:1_INTERNAL_ONLY_WALL_1,
        ex:1_INTERNAL_ONLY_WALL_2,
        ex:1_INTERNAL_ONLY_WALL_3,
        ex:1_INTERNAL_ONLY_WALL_4 ;
    bem:orientation "ONLY" ;
    bem:roomHeight 4e+00 ;
    bem:roomLength 7e+00 ;
    bem:roomWidth 7e+00 ;
    bem:zoneMultiplier 2e+00 ;
    bem:zoneName "1_INTERNAL_ONLY" ;
    bem:zoneType "1" .

ex:1_INTERNAL_ONLY_WINDOW_SYSTEM a bem:WindowSystem ;
    bem:frameArea 2.3e+01 ;
    bem:frameUValue 1e+00 ;
    bem:glazingType "Double Clear Air 2-panes" ;
    bem:shadingType "OUTSIDE-BLIND" .

ex:1_NORTH a brick:Room ;
    bem:hasSurface ex:1_NORTH_WALL_1,
        ex:1_NORTH_WALL_2,
        ex:1_NORTH_WALL_3,
        ex:1_NORTH_WALL_4 ;
    bem:orientation "NORTH" ;
    bem:roomHeight 4e+00 ;
    bem:roomLength 7e+00 ;
    bem:roomWidth 7e+00 ;
    bem:zoneMultiplier 2e+00 ;
    bem:zoneName "1_NORTH" ;
    bem:zoneType "1" .

ex:1_SOUTH a brick:Room ;
