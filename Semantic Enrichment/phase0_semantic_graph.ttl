    bem:zoneType "1" .

ex:1_EAST_WALL_1 a brick:Wall ;
    bem:externalConstruction "AW_BE_MW" ;
    bem:hasSubpart ex:1_EAST_WALL_1_SUBPART ;
    bem:internalConstruction "IW_TB" ;
    bem:wwr 0e+00 .

ex:1_EAST_WALL_1_SUBPART bem:internalFraction 5e-01 ;
    bem:side "left" .

ex:1_EAST_WALL_2 a brick:Wall ;
    bem:externalConstruction "AW_BE_MW" ;
